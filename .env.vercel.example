# ============================================================
# Vercel Environment Variables
# Yeh sab Vercel Dashboard > Project > Settings > Environment Variables me add karo
# ============================================================

# Frontend (Vite)
VITE_API_URL=https://YOUR-PROJECT.vercel.app/api
VITE_ADMIN_URL=https://YOUR-PROJECT.vercel.app/admin

# Backend (Node.js)
NODE_ENV=production
PORT=5000

# Database (PlanetScale / Railway / Aiven MySQL)
DB_HOST=YOUR_MYSQL_HOST
DB_USER=YOUR_MYSQL_USER
DB_PASS=YOUR_MYSQL_PASSWORD
DB_NAME=shreenovatech_db

# JWT
JWT_SECRET=SNT_JWT_SECRET_KEY_2024_SHREENOVATECH_CHANGE_THIS

# Base URL
BASE_URL=https://YOUR-PROJECT.vercel.app

# Frontend URL (for CORS)
FRONTEND_URL=https://YOUR-PROJECT.vercel.app

# SMTP Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=support@shreenovatech.in
SMTP_PASS=YOUR_GMAIL_APP_PASSWORD
SMTP_FROM_NAME=ShreeNova Tech
