# ── Server ────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── Database (Aiven MySQL) ────────────────────────────────────
# Option 1: Full DATABASE_URL
DATABASE_URL=mysql://user:password@host:port/dbname?ssl-mode=REQUIRED

# Option 2: Individual vars (use one or the other)
DB_HOST=your-aiven-host.aivencloud.com
DB_PORT=12345
DB_USER=avnadmin
DB_PASS=your-password
DB_NAME=shreenovatech_db
DB_SSL=true

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-secret-string-min-32-chars
JWT_EXPIRES_IN=24h

# ── URLs ──────────────────────────────────────────────────────
BASE_URL=https://api.shreenovatech.in
FRONTEND_URL=https://shreenovatech.in

# ── File Upload ───────────────────────────────────────────────
MAX_FILE_SIZE=10485760

# ── SMTP (Gmail) ──────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=support@shreenovatech.in
SMTP_PASS=your-gmail-app-password
SMTP_FROM_NAME=ShreeNova Tech
