{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://shreenovatech.onrender.com/api/:path*"
    }
  ],
  "routes": [
    {
      "src": "^/admin/assets/(.*)",
      "dest": "/admin/assets/$1"
    },
    {
      "src": "^/admin(.*)",
      "dest": "/admin/index.html"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "^/(.*)",
      "dest": "/index.html"
    }
  ]
}
